rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "maykon.euro@gmail.com" && request.auth.token.email_verified == true);
    }
    
    function isOwner(storeId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == storeId ||
        isAdmin()
      );
    }

    function isValidStore(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 50;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.customerWhatsapp is string && data.customerWhatsapp.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users mapping
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Platform Settings
    match /platform/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Stores
    match /stores/{storeId} {
      allow read: if true; // Public catalog access
      allow create: if isAuthenticated() && isValidStore(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(storeId) && isValidStore(request.resource.data);
      
      // Products
      match /products/{productId} {
        allow read: if true;
        allow write: if isOwner(storeId) && isValidProduct(request.resource.data);
      }

      // Orders
      match /orders/{orderId} {
        allow read: if isOwner(storeId);
        allow create: if isValidOrder(request.resource.data);
        allow update: if isOwner(storeId);
      }

      // Customers
      match /customers/{customerId} {
        allow read, write: if isOwner(storeId);
      }

      // Finance
      match /finance/{recordId} {
        allow read, write: if isOwner(storeId);
      }
    }
  }
}
