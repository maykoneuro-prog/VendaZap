rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /stores/{storeId}/{allPaths=**} {
      // Allow read access to everyone for product images and logos
      allow read: if true;
      // Allow write access only to authenticated users who own the store
      // (Simplified check: just authenticated for now, ideally check store ownership)
      allow write: if request.auth != null;
    }
  }
}
